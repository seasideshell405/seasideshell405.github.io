<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — 海边的小破站</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+SC:wght@500;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="grain"></div>

  <header class="site-header">
    <div class="container">
      <a href="/" class="site-logo">海边的小破站</a>

      <div class="header-right">
        <nav class="site-nav">
          <ul>
            <li><a href="/">首页</a></li>
            <li><a href="/projects/">项目</a></li>
            <li><a href="/tutorials/">教程</a></li>
            <li><a href="/blog/">随记</a></li>
            <li><a href="/gallery/">画廊</a></li>
            <li><a href="/search/">🔍</a></li>
          </ul>
        </nav>

        <button class="nav-toggle" aria-label="菜单" aria-expanded="false">
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
        </button>
      </div>
    </div>
  </header>

  <main class="site-main" id="swup">
    <div class="container transition-fade">
      {{ content | safe }}
    </div>
  </main>

  <footer class="site-footer">
    <div class="container">
      <p>&copy; {{ year }} 海边的小破站 &mdash; Powered by <a href="https://www.11ty.dev/">Eleventy</a></p>
    </div>
  </footer>

  <script src="/js/swup.js"></script>
  <script>
    new Swup();
  </script>
  <script>
    (function () {
      function handleCardClick(event) {
        var card = event.target.closest('.card[data-href]');
        if (!card) return;
        if (event.target.closest('a')) return;

        var href = card.getAttribute('data-href');
        var target = card.getAttribute('data-href-target');
        if (!href) return;

        if (target === '_self') {
          window.location.href = href;
        } else {
          window.open(href, target || '_blank', 'noopener');
        }
      }

      document.addEventListener('click', handleCardClick);
    })();
  </script>
  <script>
    (function () {
      var btn = document.querySelector('.nav-toggle');
      var nav = document.querySelector('.site-nav');
      if (!btn || !nav) return;

      function close() {
        btn.setAttribute('aria-expanded', 'false');
        nav.classList.remove('nav-open');
      }

      btn.addEventListener('click', function () {
        if (nav.classList.contains('nav-open')) {
          close();
        } else {
          btn.setAttribute('aria-expanded', 'true');
          nav.classList.add('nav-open');
        }
      });

      // 点导航链接时收回菜单
      nav.querySelectorAll('a').forEach(function (link) {
        link.addEventListener('click', close);
      });
    })();
  </script>
  <script>
    (function () {
      var header = document.querySelector('.site-header');
      if (!header) return;
      var lastScroll = window.pageYOffset || 0;
      var threshold = 30;

      window.addEventListener('scroll', function () {
        var scrollY = window.pageYOffset || 0;
        // 只在手机端生效
        if (window.innerWidth >= 640) {
          header.classList.remove('header-hidden');
          lastScroll = scrollY;
          return;
        }

        // 滚动距离太小不处理
        if (Math.abs(scrollY - lastScroll) < threshold) return;

        // 菜单开着时不隐藏
        if (document.querySelector('.site-nav.nav-open')) return;

        if (scrollY > lastScroll && scrollY > 100) {
          // 下滑 → 隐藏
          header.classList.add('header-hidden');
        } else {
          // 上滑 → 显示
          header.classList.remove('header-hidden');
        }
        lastScroll = scrollY;
      }, { passive: true });
    })();
  </script>
</body>
</html>
