# 搜索

<div class="search-box">
  <input type="text" id="search-input" placeholder="输入关键词..." autocomplete="off">
</div>

<div id="search-results" class="search-results">
  <p class="search-hint">输入关键词开始搜索</p>
</div>

<script>
  // 搜索数据
  const searchData = {{ search | dump | safe }};
  
  const searchInput = document.getElementById('search-input');
  const resultsContainer = document.getElementById('search-results');
  
  function doSearch(query) {
    if (!query.trim()) {
      resultsContainer.innerHTML = '<p class="search-hint">输入关键词开始搜索</p>';
      return;
    }
    
    const q = query.toLowerCase();
    const results = searchData.filter(item => 
      item.title.toLowerCase().includes(q) || 
      item.summary.toLowerCase().includes(q) ||
      item.type.toLowerCase().includes(q)
    );
    
    if (results.length === 0) {
      resultsContainer.innerHTML = '<p class="search-hint">没有找到相关内容</p>';
      return;
    }
    
    resultsContainer.innerHTML = results.map(item => `
      <div class="search-result-item">
        <span class="result-type">${item.type}</span>
        <h3><a href="${item.url}">${item.title}</a></h3>
        <p>${item.summary}</p>
      </div>
    `).join('');
  }
  
  searchInput.addEventListener('input', (e) => {
    doSearch(e.target.value);
  });
  
  searchInput.addEventListener('keypress', (e) => {
    if (e.key === 'Enter') {
      doSearch(e.target.value);
    }
  });
  
  // 自动聚焦
  searchInput.focus();
</script>

<style>
  .search-box {
    margin-bottom: 30px;
  }
  
  #search-input {
    width: 100%;
    max-width: 500px;
    padding: 12px 16px;
    border: 2px solid var(--border-color, #e0dcd3);
    border-radius: 8px;
    font-size: 16px;
    background: var(--bg-color, #faf9f6);
    color: var(--text-color, #3d3d3d);
    font-family: inherit;
  }
  
  #search-input:focus {
    outline: none;
    border-color: var(--link-color, #5a7a96);
  }
  
  .search-hint {
    color: var(--text-muted, #888);
    text-align: center;
    padding: 40px 0;
  }
  
  .search-result-item {
    padding: 20px 0;
    border-bottom: 1px solid var(--border-color, #e0dcd3);
  }
  
  .search-result-item:last-child {
    border-bottom: none;
  }
  
  .result-type {
    display: inline-block;
    padding: 2px 10px;
    background: var(--bg-secondary, #f5f3ef);
    border-radius: 4px;
    font-size: 12px;
    color: var(--text-muted, #666);
    margin-bottom: 8px;
  }
  
  .search-result-item h3 {
    margin: 0 0 8px 0;
    font-size: 18px;
  }
  
  .search-result-item h3 a {
    color: var(--link-color, #5a7a96);
    text-decoration: none;
  }
  
  .search-result-item h3 a:hover {
    text-decoration: underline;
  }
  
  .search-result-item p {
    margin: 0;
    color: var(--text-muted, #666);
    font-size: 14px;
    line-height: 1.6;
  }
</style>
