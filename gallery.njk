---
layout: layout.njk
title: 画廊
description: 精选图片展示
---

<div class="gallery">

  <h1>画廊</h1>

  {% if images.length > 0 %}
  <div class="gallery-grid">
  {% for img in images %}
    <a href="{{ img.url }}" target="_blank" class="gallery-item">
      <img src="{{ img.url }}" alt="{{ img.file }}" loading="lazy">
      <span class="gallery-label">{{ img.file }}（{{ img.size }}）</span>
    </a>
  {% endfor %}
  </div>
  {% else %}
  <p style="text-align:center;color:var(--c-text-muted);">暂无精选图片</p>
  {% endif %}

</div>
